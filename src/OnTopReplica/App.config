<?xml version="1.0"?>
<configuration>

  <!-- Application settings are no longer stored here: they live in a portable
       JSON file at %LOCALAPPDATA%\OnTopReplicaPlus\settings.json (see Settings.cs). -->

  <!-- Runtime support declaration -->
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7" />
  </startup>

  <!-- Windows Forms configuration for .NET 4.7 -->
  <System.Windows.Forms.ApplicationConfigurationSection>
    <add key="DpiAwareness" value="PerMonitorV2"/>
  </System.Windows.Forms.ApplicationConfigurationSection>

</configuration>
